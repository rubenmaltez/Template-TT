android/.gradle/
android/local.properties
android/captures/
android/app/release/
android/app/profile/
android/app/debug/
ios/Pods/
ios/.symlinks/
windows/flutter/ephemeral/
linux/flutter/ephemeral/
macos/flutter/ephemeral/

