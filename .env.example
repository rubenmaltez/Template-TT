# Copia este archivo a `.env` y rellena con tus valores reales.
# El `.env` está en .gitignore — NUNCA lo committees.

# --- Supabase ---
# Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...

# Sólo para Edge Functions / scripts admin. NUNCA en el binario de la app.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- PowerSync ---
# Dashboard de PowerSync → Instance settings
POWERSYNC_URL=https://YOUR_INSTANCE.powersync.journeyapps.com

# Endpoint donde la app pide el JWT (Edge Function que crearemos en supabase/functions/powersync-auth)
POWERSYNC_TOKEN_ENDPOINT=https://YOUR_PROJECT.supabase.co/functions/v1/powersync-auth

# --- PowerSync auth (sólo para la Edge Function, no para la app) ---
# Generados en PowerSync dashboard → Manage instance → JWKS / Credentials
POWERSYNC_KEY_ID=
POWERSYNC_PRIVATE_KEY=
