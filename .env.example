# ⚠️  La APP Flutter NO usa este archivo — usa `.env.example.json`
# (que se carga con `flutter run --dart-define-from-file=.env.json`).
#
# Este `.env` shell-style es sólo para Edge Functions de Supabase y scripts admin
# que corren en Node/Deno fuera del binario del cliente.

# --- Supabase (server-side: Edge Functions, scripts admin) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- PowerSync auth (sólo para la Edge Function `powersync-auth`) ---
# Generados en PowerSync dashboard → Manage instance → Credentials / JWKS
POWERSYNC_KEY_ID=
POWERSYNC_PRIVATE_KEY=
